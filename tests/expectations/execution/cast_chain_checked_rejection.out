program test.aleo;

function roundtrip_u8_i8_u8:
    input r0 as u8.private;
    cast r0 into r1 as i8;
    cast r1 into r2 as u8;
    output r2 as u8.private;

function roundtrip_i8_u8_i8:
    input r0 as i8.private;
    cast r0 into r1 as u8;
    cast r1 into r2 as i8;
    output r2 as i8.private;

constructor:
    assert.eq edition 0u16;
status: success
